"Content-Type: text/plain; charset=UTF-8\n"
"Project-Id-Version: luci-app-hysteria-realm-server\n"
"Language: zh_Hans\n"

# --- Menu ---
msgid "Hysteria Realm Server"
msgstr "Hysteria Realm 服务器"

msgid "Overview"
msgstr "概览"

msgid "Settings"
msgstr "设置"

msgid "TLS Certificate"
msgstr "TLS 证书"

msgid "Logs"
msgstr "日志"

# --- Overview ---
msgid "Please wait…"
msgstr "请稍候…"

msgid "Operation completed successfully."
msgstr "操作成功完成。"

msgid "Operation failed."
msgstr "操作失败。"

msgid "Downloading core…"
msgstr "正在下载核心…"

msgid "Detecting CPU architecture and downloading the matching binary from GitHub. This may take a minute."
msgstr "正在检测 CPU 架构并从 GitHub 下载匹配的二进制文件,可能需要一分钟。"

msgid "Core binary installed successfully."
msgstr "核心二进制文件安装成功。"

msgid "Failed to download the core binary (code %s)."
msgstr "下载核心二进制文件失败(代码 %s)。"

msgid "Collecting data…"
msgstr "正在收集数据…"

msgid "Running"
msgstr "运行中"

msgid "Stopped"
msgstr "已停止"

msgid "Service"
msgstr "服务"

msgid "Boot autostart"
msgstr "开机自启"

msgid "Enabled"
msgstr "已启用"

msgid "Disabled"
msgstr "已禁用"

msgid "Core binary"
msgstr "核心二进制"

msgid "Installed"
msgstr "已安装"

msgid "Not installed"
msgstr "未安装"

msgid "CPU / asset"
msgstr "CPU / 资源包"

msgid "(unsupported CPU — set a custom URL)"
msgstr "(不支持的 CPU——请填自定义地址)"

msgid "Listen"
msgstr "监听"

msgid "Rendezvous server for the Hysteria 2 P2P (Realms) feature. It coordinates UDP hole punching so you can host Hysteria servers behind NAT without a public IP or port forwarding."
msgstr "Hysteria 2 P2P(Realms)功能的会合服务器。它协调 UDP 打洞,使你无需公网 IP 或端口转发即可在 NAT 后方部署 Hysteria 服务器。"

msgid "Prerequisite: this rendezvous server itself must be publicly reachable. Hysteria servers and clients connect to it directly, so this router needs a public IP, or a forwarded TCP port / DDNS. It is the one component that cannot sit behind un-forwarded NAT (CGNAT will not work)."
msgstr "前提:本会合服务器自身必须能从公网访问到。Hysteria 服务端和客户端都直接连接它,因此本路由器需要公网 IP,或已转发的 TCP 端口 / DDNS。它是唯一不能位于未做转发的 NAT 后方的组件(CGNAT 无法工作)。"

msgid "Status"
msgstr "状态"

msgid "Service control"
msgstr "服务控制"

msgid "Start"
msgstr "启动"

msgid "Stop"
msgstr "停止"

msgid "Restart"
msgstr "重启"

msgid "Enable autostart"
msgstr "启用自启"

msgid "Disable autostart"
msgstr "禁用自启"

msgid "Starting service…"
msgstr "正在启动服务…"

msgid "Stopping service…"
msgstr "正在停止服务…"

msgid "Restarting service…"
msgstr "正在重启服务…"

msgid "Enabling…"
msgstr "正在启用…"

msgid "Disabling…"
msgstr "正在禁用…"

msgid "Download / Update core"
msgstr "下载 / 更新核心"

msgid "Download or update the core binary matching your router CPU, built by this project's GitHub Actions CI for all common OpenWrt architectures (x86_64, arm64, armv7/v5, mips/mipsel, mips64, riscv64, …)."
msgstr "下载或更新与你路由器 CPU 匹配的核心二进制,由本项目的 GitHub Actions CI 为所有常见 OpenWrt 架构构建(x86_64、arm64、armv7/v5、mips/mipsel、mips64、riscv64 等)。"

msgid "Connection example"
msgstr "对接配置示例"

msgid "The server address below is auto-filled from this router (IPv6 preferred). Paste the matching block into your Hysteria 2 config; adjust the address if clients reach you via a different IP or domain."
msgstr "下方的服务器地址已根据本路由器自动填入(优先 IPv6)。将对应代码块粘贴到你的 Hysteria 2 配置中;若客户端通过其他 IP 或域名访问你,请相应调整地址。"

msgid "Available endpoints"
msgstr "可用接入地址"

msgid "The WAN IPv4 address %s is private/NAT — external clients need port forwarding, a public IP, or DDNS."
msgstr "WAN 的 IPv4 地址 %s 是内网/NAT 地址——外部客户端需要端口转发、公网 IP 或 DDNS 才能连上。"

msgid "Only a LAN address was found (%s); use the address external clients actually reach this router by."
msgstr "只检测到 LAN 地址(%s);请改用外部客户端实际访问本路由器的地址。"

msgid "Detected %s: inbound IPv4 on this line is port-restricted or unavailable. Use the IPv6 endpoint below. To use IPv4 you must set the listen port to one inside your ISP-assigned MAP-E port range."
msgstr "检测到 %s:本线路的 IPv4 入站端口受限或不可用。请使用下方的 IPv6 接入地址。若要使用 IPv4,必须把监听端口设为运营商分配的 MAP-E 端口范围之内的端口。"

msgid "IPv4-over-IPv6"
msgstr "IPv4-over-IPv6"

msgid "Dual-stack detected. For clients on either protocol, point a domain with both A and AAAA records at this router and use that as the server."
msgstr "检测到双栈。为兼顾两种协议的客户端,可将同时配置 A 和 AAAA 记录的域名指向本路由器,并以该域名作为 server。"

msgid "MAP-E / port-restricted IPv4"
msgstr "MAP-E / 端口受限的 IPv4"

msgid "Shared IPv4 address: %s"
msgstr "共享 IPv4 地址:%s"

msgid "ISP-assigned IPv4 ports (auto-detected)"
msgstr "运营商分配的 IPv4 端口(自动检测)"

msgid "The listen port %s is within your assigned ports — IPv4 inbound is OK."
msgstr "监听端口 %s 在你被分配的端口范围内——IPv4 入站正常。"

msgid "The listen port %s is NOT within your assigned ports; IPv4 inbound will fail. Use port %s, or use IPv6."
msgstr "监听端口 %s 不在你被分配的端口范围内;IPv4 入站将失败。请改用端口 %s,或改用 IPv6。"

msgid "Could not auto-detect the assigned ports. Use the calculator below with the parameters from your ISP (defaults match JPIX v6plus: a=4, k=8)."
msgstr "无法自动检测到分配的端口。请用下方计算器,填入你运营商的参数(默认值对应 JPIX v6プラス:a=4、k=8)。"

msgid "Port calculator (RFC 7597 GMA)"
msgstr "端口计算器(RFC 7597 GMA)"

msgid "Offset a"
msgstr "偏移 a"

msgid "PSID length k"
msgstr "PSID 长度 k"

msgid "Compute"
msgstr "计算"

msgid "Allowed ports: %s"
msgstr "允许的端口:%s"

msgid "Listen port %s fits these parameters."
msgstr "监听端口 %s 符合这些参数。"

msgid "Listen port %s does NOT fit; first allowed port is %s."
msgstr "监听端口 %s 不符合;第一个允许的端口是 %s。"

msgid "Enter PSID (and adjust a / k) to compute the allowed ports."
msgstr "输入 PSID(并按需调整 a / k)以计算允许的端口。"

msgid "No valid ports for these parameters."
msgstr "这些参数下没有有效端口。"

msgid "Server side"
msgstr "服务端"

msgid "Client side"
msgstr "客户端"

msgid "No token is set yet. Generate one in Settings before starting the service."
msgstr "尚未设置 token。请先在“设置”中生成,再启动服务。"

# --- Settings ---
msgid "Failed to generate a token."
msgstr "生成 token 失败。"

msgid "A new random token was generated. Remember to Save & Apply."
msgstr "已生成新的随机 token。请记得点击“保存并应用”。"

msgid "Generate"
msgstr "生成"

msgid "Hysteria Realm Server — Settings"
msgstr "Hysteria Realm 服务器 — 设置"

msgid "Configure the rendezvous server. Changes take effect after Save & Apply (the service restarts automatically). Note: this server must be publicly reachable (public IP or forwarded port / DDNS) — it cannot work behind un-forwarded NAT or CGNAT."
msgstr "配置会合服务器。更改在“保存并应用”后生效(服务会自动重启)。注意:本服务器必须能从公网访问到(公网 IP,或已做端口转发 / DDNS)——在未做转发的 NAT 或 CGNAT 后方无法工作。"

msgid "General"
msgstr "常规"

msgid "Limits"
msgstr "限额"

msgid "Advanced"
msgstr "高级"

msgid "Master switch for the service."
msgstr "服务总开关。"

msgid "Listen address"
msgstr "监听地址"

msgid "Bind address. \"::\" = all interfaces, dual-stack IPv4+IPv6 (recommended); \"0.0.0.0\" = IPv4 only. Keep \"::\" on IPv6-only / MAP-E / DS-Lite lines so clients can reach it over IPv6."
msgstr "绑定地址。\"::\" = 所有接口、IPv4+IPv6 双栈(推荐);\"0.0.0.0\" = 仅 IPv4。在纯 IPv6 / MAP-E / DS-Lite 线路上请保持 \"::\",以便客户端通过 IPv6 访问。"

msgid "Listen port"
msgstr "监听端口"

msgid "TCP port for the HTTP/HTTPS rendezvous API. On MAP-E / DS-Lite lines (common in Japan), inbound IPv4 is limited to ISP-assigned ports — prefer IPv6, or set this to a port inside your allowed MAP-E range."
msgstr "HTTP/HTTPS 会合 API 使用的 TCP 端口。在 MAP-E / DS-Lite 线路(日本常见)上,IPv4 入站仅限运营商分配的端口——建议使用 IPv6,或将此端口设为你被分配的 MAP-E 端口范围之内。"

msgid "Shared token"
msgstr "共享 token"

msgid "Bearer token required for realm registration and connection. Both the Hysteria server and clients must use the same value. REQUIRED."
msgstr "用于 realm 注册与连接的 Bearer token。Hysteria 服务端与客户端必须使用相同的值。必填。"

msgid "Auto-open firewall"
msgstr "自动开放防火墙"

msgid "Automatically add an input ACCEPT rule on the WAN zone for the listen port. Disable if you manage the firewall manually."
msgstr "自动在 WAN 区域为监听端口添加 input ACCEPT 规则。若你手动管理防火墙请关闭此项。"

msgid "Max realms"
msgstr "最大 realm 数"

msgid "Maximum total number of registered realms. 0 disables the limit."
msgstr "已注册 realm 的最大总数。0 表示不限制。"

msgid "Max realms per IP"
msgstr "每 IP 最大 realm 数"

msgid "Maximum realms per client IP. 0 disables the limit."
msgstr "每个客户端 IP 的最大 realm 数。0 表示不限制。"

msgid "Debug logging"
msgstr "调试日志"

msgid "Enable verbose logs for registration, sessions and punches."
msgstr "为注册、会话和打洞过程启用详细日志。"

msgid "Trusted proxy header"
msgstr "可信代理头"

msgid "Header to read the real client IP from when behind a trusted reverse proxy/CDN (e.g. X-Forwarded-For, CF-Connecting-IP). Leave empty if not proxied — enabling it on a directly-exposed server lets clients spoof their IP."
msgstr "位于可信反向代理/CDN 后方时,用于读取真实客户端 IP 的头部(如 X-Forwarded-For、CF-Connecting-IP)。未使用代理请留空——在直接暴露的服务器上启用会让客户端伪造 IP。"

msgid "Realm name pattern"
msgstr "Realm 名称正则"

msgid "Regular expression that realm names must match."
msgstr "realm 名称必须匹配的正则表达式。"

msgid "Core version"
msgstr "核心版本"

msgid "Plugin release tag (without v) to download binaries from. Must match a release published by the release repository."
msgstr "下载二进制所用的插件发布标签(不带 v)。必须与发布仓库已发布的 Release 一致。"

msgid "Release repository"
msgstr "发布仓库"

msgid "GitHub repository (owner/name) that hosts the CI-built per-architecture binaries."
msgstr "托管 CI 构建的各架构二进制的 GitHub 仓库(owner/name)。"

msgid "Custom download URL"
msgstr "自定义下载地址"

msgid "Override the full binary download URL (highest priority). Use it only for CPUs without a published binary — point it to a self-compiled binary. Leave empty for auto-detection."
msgstr "覆盖完整的二进制下载地址(最高优先级)。仅用于没有已发布二进制的 CPU——指向你自行编译的二进制。留空则自动检测。"

# --- TLS ---
msgid "Serve the rendezvous API over HTTPS. When TLS is disabled the server runs plain HTTP — fine behind another TLS-terminating proxy, but not recommended for direct exposure."
msgstr "通过 HTTPS 提供会合 API。禁用 TLS 时服务以明文 HTTP 运行——位于其他 TLS 终止代理后方时尚可,但不建议直接暴露。"

msgid "Enable TLS"
msgstr "启用 TLS"

msgid "Use the certificate and key below. The service falls back to HTTP if either file is missing."
msgstr "使用下方的证书和密钥。若任一文件缺失,服务将回退为 HTTP。"

msgid "Certificate path"
msgstr "证书路径"

msgid "Private key path"
msgstr "私钥路径"

msgid "Generating certificate…"
msgstr "正在生成证书…"

msgid "Creating a self-signed ECDSA certificate…"
msgstr "正在创建自签名 ECDSA 证书…"

msgid "Certificate generated at %s. Enable TLS above, then Save & Apply."
msgstr "证书已生成于 %s。请在上方启用 TLS,然后“保存并应用”。"

msgid "Certificate generation failed."
msgstr "证书生成失败。"

msgid "Generate self-signed certificate"
msgstr "生成自签名证书"

msgid "Quick self-signed certificate"
msgstr "快速自签名证书"

msgid "Generates a certificate/key pair at the configured paths. Self-signed certificates require clients to disable certificate verification (insecure: true in the Hysteria realm config)."
msgstr "在配置的路径生成证书/密钥对。自签名证书需要客户端关闭证书校验(在 Hysteria realm 配置中设置 insecure: true)。"

msgid "Common name (CN)"
msgstr "通用名称(CN)"

msgid "Valid days"
msgstr "有效天数"

# --- Logs ---
msgid "Service logs"
msgstr "服务日志"

msgid "Live output captured from the service via the system log (logread). Updates every 5 seconds."
msgstr "通过系统日志(logread)实时抓取的服务输出。每 5 秒更新一次。"

msgid "Refresh now"
msgstr "立即刷新"

msgid "Auto-scroll to bottom"
msgstr "自动滚动到底部"

msgid "(no log entries yet — start the service to produce logs)"
msgstr "(暂无日志——启动服务后即可产生日志)"
