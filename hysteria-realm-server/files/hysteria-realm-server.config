
config hysteria-realm-server 'main'
	# Master switch. 0 = disabled, 1 = enabled
	option enabled '0'

	# --- Listen ---
	# Bind address:
	#   ::        all interfaces, dual-stack (IPv4 + IPv6)  <- default
	#   0.0.0.0   all interfaces, IPv4 only
	#   <addr>    a specific IPv4 or IPv6 literal address
	# On IPv6-only / MAP-E / DS-Lite lines, keep :: so clients can reach it over IPv6.
	option listen_addr '::'
	option listen_port '8443'

	# --- Auth ---
	# Shared bearer token (REQUIRED). Generate one from the LuCI panel.
	option token ''

	# --- TLS ---
	# 0 = plain HTTP, 1 = HTTPS using cert_path / key_path below.
	option tls_enabled '0'
	option cert_path '/etc/hysteria-realm-server/cert.pem'
	option key_path '/etc/hysteria-realm-server/key.pem'

	# --- Limits ---
	option max_realms '65536'
	option max_realms_per_ip '4'

	# --- Advanced ---
	option debug '0'
	# Header used to read the real client IP behind a trusted proxy/CDN
	# (e.g. X-Forwarded-For, CF-Connecting-IP). Leave empty if not proxied.
	option trusted_proxy_header ''
	option realm_name_pattern '^[A-Za-z0-9][A-Za-z0-9_-]{0,63}$'

	# --- Firewall ---
	# 1 = automatically open the listen port on the WAN zone (input ACCEPT).
	option open_firewall '1'

	# --- Binary management ---
	# Plugin release tag (without leading v) to download binaries from. The
	# CI publishes the per-arch core binaries under this release tag.
	option version '1.1.0'
	# GitHub repo (owner/name) hosting the CI-built per-arch binaries.
	option release_repo 'yukiinagato/luci-hysteria-realm-server'
	# Optional: override the full download URL (highest priority). Useful for
	# CPUs without a published binary. Leave empty for auto-detect.
	option download_url ''
